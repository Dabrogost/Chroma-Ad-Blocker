{
  "manifest_version": 3,
  "name": "YT Chroma – YouTube Ad Blocker",
  "version": "1.0.0",
  "description": "Multi-layered YouTube ad blocker using ad-acceleration, network blocking, and cosmetic filtering.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "main-world.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "yt_original_rules",
        "enabled": true,
        "path": "rules.json"
      },
      {
        "id": "yt_ad_rules_part1",
        "enabled": true,
        "path": "rules_1.json"
      },
      {
        "id": "yt_ad_rules_part2",
        "enabled": true,
        "path": "rules_2.json"
      },
      {
        "id": "yt_ad_rules_part3",
        "enabled": true,
        "path": "rules_3.json"
      },
      {
        "id": "yt_ad_rules_part4",
        "enabled": true,
        "path": "rules_4.json"
      },
      {
        "id": "yt_ad_rules_part5",
        "enabled": true,
        "path": "rules_5.json"
      },
      {
        "id": "yt_ad_rules_part6",
        "enabled": true,
        "path": "rules_6.json"
      },
      {
        "id": "yt_ad_rules_part7",
        "enabled": true,
        "path": "rules_7.json"
      },
      {
        "id": "yt_ad_rules_part8",
        "enabled": true,
        "path": "rules_8.json"
      },
      {
        "id": "yt_ad_rules_part9",
        "enabled": true,
        "path": "rules_9.json"
      },
      {
        "id": "yt_ad_rules_part10",
        "enabled": true,
        "path": "rules_10.json"
      }
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}