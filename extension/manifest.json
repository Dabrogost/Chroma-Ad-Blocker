{
  "manifest_version": 3,
  "minimum_chrome_version": "122",
  "name": "Chroma Ad-Blocker",
  "version": "1.0.0",
  "description": "Multi-layered ad-blocker using ad-acceleration, network blocking, and cosmetic filtering.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "unlimitedStorage",
    "tabs",
    "alarms",
    "scripting",
    "userScripts",
    "proxy",
    "webRequest",
    "webRequestAuthProvider"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.amazon.com/*",
        "*://*.amazon.de/*",
        "*://*.amazon.co.uk/*",
        "*://*.amazon.co.jp/*",
        "*://*.amazon.ca/*",
        "*://*.amazon.fr/*",
        "*://*.amazon.it/*",
        "*://*.amazon.es/*",
        "*://*.primevideo.com/*"
      ],
      "js": [
        "core/messaging.js",
        "content/protection.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.amazon.com/*",
        "*://*.amazon.de/*",
        "*://*.amazon.co.uk/*",
        "*://*.amazon.co.jp/*",
        "*://*.amazon.ca/*",
        "*://*.amazon.fr/*",
        "*://*.amazon.it/*",
        "*://*.amazon.es/*",
        "*://*.primevideo.com/*"
      ],
      "js": [
        "content/interceptor.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content/yt_handler.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.amazon.de/*",
        "*://*.amazon.co.uk/*",
        "*://*.amazon.co.jp/*",
        "*://*.amazon.ca/*",
        "*://*.amazon.fr/*",
        "*://*.amazon.it/*",
        "*://*.amazon.es/*",
        "*://*.primevideo.com/*"
      ],
      "js": [
        "content/prm_handler.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "*://*.bellyfull.net/*",
        "*://*.allrecipes.com/*",
        "*://*.foodnetwork.com/*",
        "*://*.epicurious.com/*",
        "*://*.bbcgoodfood.com/*",
        "*://*.thekitchn.com/*",
        "*://*.seriouseats.com/*",
        "*://*.recipetineats.com/*",
        "*://*.smittenkitchen.com/*",
        "*://*.budgetbytes.com/*",
        "*://*.pinchofyum.com/*",
        "*://*.sallysbakingaddiction.com/*",
        "*://*.minimalistbaker.com/*",
        "*://*.thewoksoflife.com/*",
        "*://*.americastestkitchen.com/*",
        "*://cooking.nytimes.com/*",
        "*://*.weelicious.com/*",
        "*://*.pcgamer.com/*"
      ],
      "js": [
        "content/recipes.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "oisd_rules_1",
        "enabled": true,
        "path": "rules/rules_oisd_1.json"
      },
      {
        "id": "oisd_rules_2",
        "enabled": true,
        "path": "rules/rules_oisd_2.json"
      },
      {
        "id": "oisd_rules_3",
        "enabled": true,
        "path": "rules/rules_oisd_3.json"
      },
      {
        "id": "oisd_rules_4",
        "enabled": true,
        "path": "rules/rules_oisd_4.json"
      },
      {
        "id": "oisd_rules_5",
        "enabled": true,
        "path": "rules/rules_oisd_5.json"
      },
      {
        "id": "oisd_rules_6",
        "enabled": true,
        "path": "rules/rules_oisd_6.json"
      },
      {
        "id": "oisd_rules_7",
        "enabled": true,
        "path": "rules/rules_oisd_7.json"
      },
      {
        "id": "oisd_rules_8",
        "enabled": true,
        "path": "rules/rules_oisd_8.json"
      },
      {
        "id": "oisd_rules_9",
        "enabled": true,
        "path": "rules/rules_oisd_9.json"
      },
      {
        "id": "oisd_rules_10",
        "enabled": true,
        "path": "rules/rules_oisd_10.json"
      },
      {
        "id": "custom_static_rules",
        "enabled": true,
        "path": "rules/rules_custom.json"
      },
      {
        "id": "recipe_ad_rules",
        "enabled": true,
        "path": "rules/rules_recipes.json"
      }
    ]
  },
  "action": {
    "default_popup": "ui/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "ui/settings.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
